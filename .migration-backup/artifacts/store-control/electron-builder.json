{
  "appId": "com.auc.clinic-inventory",
  "productName": "AUC Clinic Inventory",
  "copyright": "AUC Clinic",
  "directories": {
    "output": "dist/installer",
    "buildResources": "public"
  },
  "extraMetadata": {
    "main": "electron/main.cjs"
  },
  "files": [
    "dist/electron/**",
    "electron/main.cjs",
    "package.json"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "public/icon.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "AUC Clinic Inventory",
    "installerIcon": "public/icon.png",
    "uninstallerIcon": "public/icon.png"
  },
  "portable": {
    "artifactName": "AUC-Clinic-Inventory-Portable.exe"
  }
}
