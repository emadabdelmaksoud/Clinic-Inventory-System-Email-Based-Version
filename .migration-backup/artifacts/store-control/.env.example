# ============================================================
# AUC Clinic Inventory – Environment Variables
# ============================================================
# Copy this file to .env.local for local development,
# or paste these into Vercel's "Environment Variables" panel.

# ── Supabase (required for cloud mode) ──────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# ── Without these two vars the app runs in local-only mode ──
# (data lives in the browser's IndexedDB via Dexie)
