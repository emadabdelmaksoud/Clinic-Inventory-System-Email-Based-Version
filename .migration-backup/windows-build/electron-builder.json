{
  "appId": "com.auclinic.inventory",
  "productName": "Clinic Inventory",
  "copyright": "Copyright © 2025 AUC Clinic",
  "buildVersion": "1.0.0",

  "directories": {
    "output": "dist/electron",
    "buildResources": "icons"
  },

  "files": [
    "main.cjs",
    "preload.cjs",
    "package.json",
    "dist/public/**/*"
  ],

  "win": {
    "target": [
      { "target": "nsis",     "arch": ["x64"] },
      { "target": "portable", "arch": ["x64"] }
    ],
    "icon": "icons/icon.ico",
    "publisherName": "AUC Clinic",
    "requestedExecutionLevel": "asInvoker",
    "artifactName": "${productName} ${version} Setup.${ext}"
  },

  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Clinic Inventory",
    "menuCategory": "AUC Clinic",
    "deleteAppDataOnUninstall": false,
    "installerIcon": "icons/icon.ico",
    "uninstallerIcon": "icons/icon.ico",
    "installerHeaderIcon": "icons/icon.ico",
    "displayLanguageSelector": false,
    "artifactName": "${productName} ${version} Setup.${ext}"
  }
}
